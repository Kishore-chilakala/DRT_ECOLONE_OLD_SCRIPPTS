{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
"strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "types": ["node", "@playwright/test"]
  },
  "include": ["tests/**/*.ts", "tests/**/*.spec.ts"],
  "exclude": ["node_modules", "dist"]
}
