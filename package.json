{
  "name": "drt_ecolone_old_scrippts",
  "version": "1.0.0",
  "description": "This repository contains the source code and test automation old scripts for the project.",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:ts": "npx playwright test tests/all-scenarios.spec.ts --headed --timeout=120000",
    "test:scenario1": "npx playwright test tests/scenario1-login.spec.js --headed",
    "test:scenario2": "npx playwright test tests/scenario2-createTrip.spec.js --headed",
    "test:scenario3": "npx playwright test tests/scenario3-createClient.spec.js --headed",
    "test:scenario4": "npx playwright test tests/scenario4-batchOptimization.spec.js --headed",
    "test:scenario5": "npx playwright test tests/scenario5-sendMessages.spec.js --headed",
    "test:all:headed": "npx playwright test --headed --timeout=120000",
    "test:report": "npx playwright show-report",
"test:debug": "npx playwright test --debug"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kishore-chilakala/DRT_ECOLONE_OLD_SCRIPPTS.git"
  },
  "keywords": [
    "playwright",
    "automation",
    "ecolane",
    "drt",
    "e2e",
    "typescript"
  ],
